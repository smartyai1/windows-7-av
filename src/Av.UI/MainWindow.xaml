<Window x:Class="Av.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Av.UI Security Center"
        Height="520"
        Width="920"
        Background="#FF0B1B38"
        Foreground="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="30" FontWeight="SemiBold" Text="Windows Security (Prototype)" />
            <TextBlock Margin="0,8,0,0" Opacity="0.85" Text="Defender-style dashboard for scan status, threat actions, and update health." />
        </StackPanel>

        <Border Grid.Row="2" Padding="20" CornerRadius="8" Background="#FF112B56">
            <StackPanel>
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Virus &amp; threat protection" />
                <TextBlock Margin="0,10,0,0" Text="Status: Protected" />
                <TextBlock Margin="0,4,0,0" Text="Last quick scan: 5 minutes ago" />
                <TextBlock Margin="0,4,0,0" Text="Signatures: up to date" />
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Width="160" Height="36" Content="Quick scan" Margin="0,0,12,0" />
                    <Button Width="220" Height="36" Content="Protection history" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
